{
  "info": {
    "name": "Online Shop API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/api/categories/"
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/api/categories/1/"
          }
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/api/categories/1/products/"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"name\": \"New Category\"}"},
            "url": "http://127.0.0.1:8000/api/categories/"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"name\": \"Updated Category\"}"},
            "url": "http://127.0.0.1:8000/api/categories/1/"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "http://127.0.0.1:8000/api/categories/1/"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/api/products/"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/api/products/1/"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"name\": \"New Product\", \"price\": 99999, \"description\": \"Test\", \"count\": 10, \"is_active\": true, \"category\": 1}"},
            "url": "http://127.0.0.1:8000/api/products/"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"name\": \"Updated Product\", \"price\": 88888, \"description\": \"New\", \"count\": 5, \"is_active\": true, \"category\": 1}"},
            "url": "http://127.0.0.1:8000/api/products/1/"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "http://127.0.0.1:8000/api/products/1/"
          }
        }
      ]
    }
  ]
}